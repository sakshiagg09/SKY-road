{
  "name": "sky-road",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4.2.0",
    "@sap-cloud-sdk/core": "^1.54.2",
    "@sap-cloud-sdk/http-client": "^4.2.0",
    "@sap-cloud-sdk/resilience": "^4.1.2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "dotenv": "^17.2.3",
    "express": "^4",
    "passport": "^0.7.0",
    "react-router-dom": "^7.9.6",
    "sap-cf-axios": "^1.0.2"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9.5.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "xsuaa",
      "SKY_APP": {
        "kind": "odata-v2",
        "credentials": {
          "destination": "Sky_App"
        }
      },
      "destinations": true,
      "[production]": {
        "auth": "xsuaa"
      },
      "[development]": {
        "auth": "mocked"
      }
    }
  }
}
