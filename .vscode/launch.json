{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Approuter (local)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/approuter/run-local.js",
      "cwd": "${workspaceFolder}/approuter",
      "console": "integratedTerminal",
      "env": {
        "PORT": "5001",
        "DEBUG": "approuter:*"
      }
    },
    {
      "name": "CAP service (hybrid debug)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cds"],
      "program": "watch",
      "args": ["--profile", "hybrid"],
      "env": {
        "PORT": "4004",
        "CDS_ENV": "hybrid"
      },
      "console": "integratedTerminal",
      "outputCapture": "std",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Approuter + CAP (hybrid debug)",
      "configurations": [
        "CAP service (hybrid debug)",
        "Approuter (local)"
      ]
    }
  ]
}
