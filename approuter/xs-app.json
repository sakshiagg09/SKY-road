{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/auth/exchange$",
      "target": "/api/auth/exchange",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false,
      "forwardAuthToken": true
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false,
      "forwardAuthToken": true
    },
    {
      "source": "^/(.*\\.(?:js|css|map|png|jpg|jpeg|gif|svg|ico|webp|woff2?|ttf|eot|json))$",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "/index.html",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ]
}
